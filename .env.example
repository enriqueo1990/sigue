# ─── SIGUE · variables de entorno ───────────────────────────────
# Copia este archivo a .env.local y completa los valores cuando
# tengas las cuentas. El sitio funciona sin ellas (sin contador y
# guardando los correos solo en consola).

# Contador de descargas — Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Newsletter — MailerLite (https://www.mailerlite.com)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
